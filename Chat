-- Функция отрисовки сообщений
local function addMessage(senderName, messageText, isLocal)
    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, 0, 0, 20)
    TextLabel.BackgroundTransparency = 1
    TextLabel.Font = Enum.Font.SourceSansBold
    TextLabel.TextSize = 16
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.RichText = true
    
    -- Белый текст, цветные ники и легкая тень для читаемости на любом фоне
    local nameColor = isLocal and "rgb(100, 210, 255)" or "rgb(255, 180, 50)"
    TextLabel.Text = string.format("<font color='%s'>[%s]</font>: <font color='rgb(255,255,255)'>%s</font>", nameColor, senderName, messageText)
    TextLabel.TextStrokeTransparency = 0.75
    TextLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    TextLabel.Parent = ScrollingFrame
    
    -- Автоматический скролл вниз
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
    ScrollingFrame.CanvasPosition = Vector2.new(0, UIListLayout.AbsoluteContentSize.Y)
end

-- Переключение чата по кнопке
ToggleButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

-- Обработка отправки
TextBox.FocusLost:Connect(function(enterPressed)
    if TextBox.Text ~= "" then
        local msg = TextBox.Text
        TextBox.Text = ""
        
        -- Сразу выводим сообщение у себя на экране (исправляет пустой чат)
        addMessage(LocalPlayer.Name, msg, true)
        
        -- Отправляем пакет другим обладателям скрипта
        pcall(function()
            ChatRemote:FireServer(msg)
        end)
    end
end)

-- Прием пакетов от других игроков
ChatRemote.OnClientEvent:Connect(function(sender, msg)
    if typeof(sender) == "Instance" and sender:IsA("Player") and sender ~= LocalPlayer and typeof(msg) == "string" then
        addMessage(sender.Name, msg, false)
    end
end)
